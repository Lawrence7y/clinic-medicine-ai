.custom-tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid #eee;
  z-index: 100;
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 8rpx 0;
}

.tab-bar-item .tab-text {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

.tab-bar-item.active .tab-text {
  color: #222222;
}

.tab-bar-item.active .tab-icon {
  color: #222222;
}
