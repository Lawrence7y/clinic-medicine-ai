.ai-operations-page {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.panel {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.quick-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.quick-item {
  background: #e2e8f0;
  color: #334155;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
}

.model-tag {
  font-size: 20rpx;
  color: #0f766e;
  background: #ccfbf1;
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
}

.panel-text {
  font-size: 26rpx;
  color: #334155;
  line-height: 1.6;
  white-space: pre-wrap;
}

.list-item {
  font-size: 26rpx;
  color: #334155;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

.empty {
  font-size: 24rpx;
  color: #94a3b8;
}

.snapshot-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.snapshot-item {
  background: #f8fafc;
  border-radius: 12rpx;
  padding: 16rpx;
  text-align: center;
}

.snapshot-num {
  font-size: 36rpx;
  color: #0f766e;
  font-weight: 700;
}

.snapshot-label {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
}
