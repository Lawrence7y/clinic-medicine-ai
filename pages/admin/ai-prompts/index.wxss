.page { min-height: 100vh; background: #f6f7fb; padding: 20rpx; }
.card { background: #fff; border-radius: 12rpx; padding: 20rpx; }
.title { font-size: 30rpx; font-weight: 600; margin-bottom: 12rpx; color: #111827; }
.label { font-size: 24rpx; color: #374151; margin: 12rpx 0 8rpx; }
.textarea { width: 100%; min-height: 180rpx; background: #f8fafc; border: 1rpx solid #e5e7eb; border-radius: 10rpx; padding: 12rpx; box-sizing: border-box; margin-bottom: 12rpx; }
