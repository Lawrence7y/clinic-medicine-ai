.system-config-container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.config-list {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.config-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.config-item:last-child {
  border-bottom: none;
}

.config-label {
  font-size: 28rpx;
  color: #333;
}

.config-value {
  flex: 1;
  max-width: 300rpx;
  text-align: right;
}

.save-button {
  padding: 40rpx 30rpx;
}

.textarea {
  width: 100%;
  min-height: 140rpx;
  background: #f8fafc;
  border: 1rpx solid #e5e7eb;
  border-radius: 10rpx;
  padding: 12rpx;
  box-sizing: border-box;
  text-align: left;
}
