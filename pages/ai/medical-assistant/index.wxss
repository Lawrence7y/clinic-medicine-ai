.medical-ai-page {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.panel {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 14rpx;
}

.panel-text {
  font-size: 26rpx;
  color: #334155;
  line-height: 1.6;
  white-space: pre-wrap;
}

.row {
  display: flex;
  font-size: 25rpx;
  margin-bottom: 8rpx;
}

.label {
  width: 100rpx;
  color: #64748b;
  flex-shrink: 0;
}

.value {
  color: #334155;
  flex: 1;
  word-break: break-word;
}

.actions {
  margin-top: 4rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
