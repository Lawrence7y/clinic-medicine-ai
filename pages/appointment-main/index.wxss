.appointment-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 140rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f5f7fb 0%, #edf2f7 100%);
}

.hero-card,
.section-card {
  background: #ffffff;
  border-radius: 28rpx;
  box-shadow: 0 12rpx 36rpx rgba(15, 23, 42, 0.06);
}

.hero-card {
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
}

.hero-badge {
  display: inline-flex;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #0f766e;
  background: #ccfbf1;
}

.hero-title {
  display: block;
  margin-top: 22rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
}

.hero-desc {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #6b7280;
}

.section-card {
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.section-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.date-scroll,
.status-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.date-list,
.status-list {
  display: flex;
  gap: 18rpx;
}

.date-chip,
.status-chip {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 26rpx;
  border-radius: 22rpx;
  background: #f3f4f6;
  color: #4b5563;
}

.date-chip {
  min-width: 128rpx;
  flex-direction: column;
  gap: 8rpx;
}

.date-chip.active,
.status-chip.active {
  background: #111827;
  color: #ffffff;
}

.date-week {
  font-size: 22rpx;
}

.date-value {
  font-size: 28rpx;
  font-weight: 700;
}

.status-chip {
  font-size: 24rpx;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.info-card {
  border-radius: 24rpx;
  border: 1rpx solid #e5e7eb;
  background: #fbfdff;
  padding: 24rpx;
}

.card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
}

.card-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding-top: 18rpx;
  font-size: 25rpx;
}

.meta-label {
  color: #6b7280;
}

.meta-value {
  color: #111827;
  font-weight: 600;
  text-align: right;
}

.card-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 999;
  background: rgba(15, 23, 42, 0.45);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
}

.modal-panel {
  width: 100%;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 34rpx 28rpx 40rpx;
  box-sizing: border-box;
}

.modal-header {
  margin-bottom: 24rpx;
}

.modal-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.modal-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.field-group {
  margin-bottom: 22rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 25rpx;
  color: #374151;
}

.picker-field,
.input-field {
  width: 100%;
  min-height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  border: 1rpx solid #d1d5db;
  background: #f9fafb;
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #111827;
}

.input-field {
  height: 88rpx;
}

.modal-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 28rpx;
}

.modal-actions t-button {
  flex: 1;
}
