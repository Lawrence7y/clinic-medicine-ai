.appointment-detail-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.state-actions {
  padding: 0 32rpx 80rpx;
  display: flex;
  justify-content: center;
}

/* 状态区域 */
.status-section {
  padding: 60rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #fff;
}

.status-text {
  font-size: 36rpx;
  font-weight: bold;
  margin-top: 20rpx;
}

/* 信息区域 */
.info-section {
  padding: 30rpx;
}

.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-left: 12rpx;
}

.info-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  font-size: 28rpx;
}

.info-row .label {
  color: #999;
  width: 140rpx;
  flex-shrink: 0;
}

.info-row .value {
  color: #333;
  flex: 1;
  line-height: 1.5;
}

/* 操作区域 */
.action-section {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-section t-button {
  width: 100%;
}
