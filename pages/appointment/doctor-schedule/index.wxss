.doctor-schedule-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 日期选择器 */
.date-selector {
  background-color: #fff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.date-scroll {
  white-space: nowrap;
}

.date-list {
  display: flex;
  padding: 0 20rpx;
}

.date-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  padding: 20rpx 30rpx;
  margin-right: 20rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  transition: all 0.3s;
}

.date-item.active {
  background-color: #222222;
}

.date-item .week-day {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.date-item.active .week-day {
  color: #fff;
}

.date-item .date {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.date-item.active .date {
  color: #fff;
}

/* 筛€夊尯鍩?*/
.filter-section {
  background-color: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eee;
}

.picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

/* 排班列〃 */
.schedule-list {
  padding: 20rpx;
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-state t-icon {
  margin-bottom: 20rpx;
}

.schedule-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.schedule-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.doctor-info {
  margin-bottom: 20rpx;
}

.doctor-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.doctor-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.doctor-title {
  font-size: 24rpx;
  color: #222222;
  background-color: #f0f2ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.department-tag {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.department-tag t-icon {
  margin-right: 8rpx;
}

.time-info {
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.time-range {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.time-range t-icon {
  margin-right: 12rpx;
}

.slots-info {
  display: flex;
  align-items: center;
  font-size: 26rpx;
}

.slots-info .available {
  color: #4caf50;
  font-weight: 500;
}

.slots-info .total {
  color: #999;
  margin-left: 8rpx;
}

.action-btn {
  display: flex;
  justify-content: flex-end;
}

/* 寮圭獥 */
.modal-content {
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 24rpx 24rpx 32rpx;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-body {
  padding-top: 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.tips {
  font-size: 24rpx;
  color: #999;
  padding-top: 8rpx;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding-top: 16rpx;
}

.modal-footer t-button {
  flex: 1;
}

