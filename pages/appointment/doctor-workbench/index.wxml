<view class="page">
  <view class="header">
    <text class="title">医生工作台</text>
    <text class="desc">今日预约、待处理事项与库存预警</text>
  </view>

  <async-state
    wx:if="{{uiState === 'loading'}}"
    mode="loading"
    title="{{texts.loading}}"
  />

  <async-state
    wx:elif="{{uiState === 'error'}}"
    mode="error"
    title="{{errorText || texts.loadFailed}}"
    buttonText="{{texts.retry}}"
    bind:retry="onRetry"
  />

  <block wx:else>
    <view class="stats">
      <view class="stat-item">
        <text class="num">{{stats.pendingCount}}</text>
        <text class="label">待确认</text>
      </view>
      <view class="stat-item">
        <text class="num">{{stats.confirmedCount}}</text>
        <text class="label">已确认</text>
      </view>
      <view class="stat-item">
        <text class="num">{{stats.todayCount}}</text>
        <text class="label">今日预约</text>
      </view>
      <view class="stat-item">
        <text class="num">{{stats.nearVisitCount}}</text>
        <text class="label">临近就诊</text>
      </view>
      <view class="stat-item stat-item--warning">
        <text class="num">{{stats.stockWarningCount}}</text>
        <text class="label">库存预警</text>
      </view>
    </view>

    <view class="section">
      <view class="section-title">医生待办</view>
      <view wx:if="{{todoList.length === 0}}" class="empty">暂无待办事项</view>
      <view
        wx:for="{{todoList}}"
        wx:key="appointmentId"
        class="todo-row"
        bindtap="openAppointmentDetail"
        data-id="{{item.appointmentId || item.id}}"
      >
        <view class="left">
          <text class="name">{{item.patientName || '-'}}</text>
          <text class="meta">{{item.appointmentDate || '-'}} {{item.appointmentTime || '-'}}</text>
        </view>
        <text class="status">{{item.statusText || item.status || '-'}}</text>
      </view>
    </view>

    <view class="section section--warning">
      <view class="section-title">库存预警</view>
      <view wx:if="{{stockWarnings.length === 0}}" class="empty">暂无库存预警</view>
      <view
        wx:for="{{stockWarnings}}"
        wx:key="id"
        class="todo-row warning-row"
        bindtap="openMedicineDetail"
        data-id="{{item.id}}"
      >
        <view class="left">
          <text class="name">{{item.name || '-'}}</text>
          <text class="meta">{{item.warningText}}</text>
        </view>
        <text class="status status--warning">查看</text>
      </view>
    </view>
  </block>

  <t-toast id="t-toast" />
</view>
