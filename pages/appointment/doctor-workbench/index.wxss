.page { min-height: 100vh; background: #f6f7fb; padding: 20rpx; }
.header { background: #fff; border-radius: 14rpx; padding: 24rpx; margin-bottom: 16rpx; }
.title { display: block; font-size: 34rpx; font-weight: 600; color: #111827; }
.desc { display: block; margin-top: 8rpx; color: #6b7280; font-size: 24rpx; }
.stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12rpx; margin-bottom: 16rpx; }
.stat-item { background: #fff; border-radius: 12rpx; padding: 20rpx; }
.stat-item--warning { border: 1rpx solid #fde68a; background: #fffbeb; }
.num { display: block; font-size: 36rpx; font-weight: 700; color: #1f2937; }
.label { display: block; margin-top: 6rpx; font-size: 22rpx; color: #6b7280; }
.section { background: #fff; border-radius: 12rpx; padding: 20rpx; }
.section--warning { margin-top: 16rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: #111827; margin-bottom: 10rpx; }
.empty { color: #9ca3af; font-size: 24rpx; padding: 18rpx 0; }
.todo-row { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f1f5f9; }
.warning-row:last-child { border-bottom: none; }
.left { display: flex; flex-direction: column; gap: 6rpx; }
.name { font-size: 28rpx; color: #111827; }
.meta { font-size: 22rpx; color: #6b7280; }
.status { font-size: 22rpx; color: #2563eb; }
.status--warning { color: #d97706; }
