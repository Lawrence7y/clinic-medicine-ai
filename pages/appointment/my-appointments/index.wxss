.my-appointments-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.search-section {
  padding: 20rpx 30rpx;
  background: #fff;
}

/* 筛选栏 */
.filter-section {
  background: #fff;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.filter-scroll {
  white-space: nowrap;
}

.filter-list {
  display: flex;
  padding: 0 20rpx;
}

.filter-item {
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
}

.filter-item.active {
  background: #222222;
  color: #fff;
}

/* 预约列表 */
.appointment-list {
  padding: 0 30rpx;
}

.appointment-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.appointment-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.doctor-info {
  flex: 1;
}

.doctor-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.card-subtitle {
  display: block;
  margin-bottom: 8rpx;
  font-size: 24rpx;
  color: #666;
}

.department {
  font-size: 26rpx;
  color: #666;
}

.appointment-body {
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  font-size: 28rpx;
}

.info-row t-icon {
  margin-right: 12rpx;
}

.info-row .label {
  color: #999;
  width: 140rpx;
}

.info-row .value {
  color: #333;
  flex: 1;
}

.queue-info-row {
  margin-top: 12rpx;
  padding: 12rpx 16rpx;
  background: #f0f9ff;
  border-radius: 8rpx;
}

.queue-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.appointment-footer {
  border-top: 1rpx solid #eee;
  padding-top: 20rpx;
}

.actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
}

/* 被叫号提醒横幅 */
.called-alert {
  margin: 20rpx 30rpx;
  padding: 24rpx;
  background: linear-gradient(135deg, #ff6b6b, #ee5a5a);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 107, 0.3);
}

.called-alert-content {
  display: flex;
  align-items: center;
}

.called-alert-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.called-alert-text {
  flex: 1;
}

.called-alert-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.called-alert-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 被叫号的卡片样式 */
.called-card {
  border: 2rpx solid #ff6b6b;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 107, 0.2);
}

/* 叫号提示 */
.called-hint {
  background: linear-gradient(135deg, #fff5f5, #ffe8e8);
  border-radius: 8rpx;
  padding: 16rpx;
}

.called-hint-text {
  display: block;
  font-size: 28rpx;
  color: #ff6b6b;
  font-weight: bold;
  text-align: center;
}

/* 叫号标签 */
.called-tag {
  margin-left: 12rpx;
}
