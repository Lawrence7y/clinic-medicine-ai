.schedule-manage-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 日期选择器 */
.date-selector {
  background-color: #fff;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.date-scroll {
  white-space: nowrap;
}

.date-list {
  display: flex;
  padding: 0 20rpx;
}

.date-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 120rpx;
  padding: 20rpx 30rpx;
  margin-right: 20rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  transition: all 0.3s;
}

.date-item.active {
  background-color: #222222;
}

.date-item .week-day {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.date-item.active .week-day {
  color: #fff;
}

.date-item .date {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.date-item.active .date {
  color: #fff;
}

/* 操作?*/
.action-bar {
  background-color: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #eee;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.action-bar-left {
  flex: 1;
}

.action-bar-right {
  flex-shrink: 0;
}

.filter-picker {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background-color: #f5f5f5;
  font-size: 26rpx;
  color: #333;
}

.filter-picker t-icon {
  margin-right: 8rpx;
}

/* 排班列〃 */
.schedule-list {
  padding: 20rpx;
}

.loading-state {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 150rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-state t-icon {
  margin-bottom: 20rpx;
}

.schedule-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.schedule-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.doctor-info {
  display: flex;
  align-items: center;
}

.doctor-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-right: 16rpx;
}

.doctor-title {
  font-size: 24rpx;
  color: #222222;
  background-color: #f0f2ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.department-tag {
  font-size: 24rpx;
  color: #fff;
  background-color: #222222;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.card-body {
  background-color: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: #333;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-row t-icon {
  margin-right: 12rpx;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

/* 弹窗样式 */
.modal-content {
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.modal-body {
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item .label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.form-item .value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.picker-value {
  padding: 20rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.time-picker-value {
  padding: 20rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

