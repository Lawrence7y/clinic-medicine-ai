.contact-doctor-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

/* 页面标题 */
.page-header {
  background: #fff;
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
}

.page-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 医生列表 */
.doctor-list {
  padding: 0 30rpx;
}

.doctor-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.doctor-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 医生头部信息 */
.doctor-header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.avatar-container {
  margin-right: 24rpx;
}

.default-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #222222 0%, #222222 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.default-avatar-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

.doctor-basic {
  flex: 1;
}

.doctor-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.doctor-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

/* 联系方式 */
.contact-info {
  margin: 0;
}
