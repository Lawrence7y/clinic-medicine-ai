.login-container {
  background: #ffffff;
  min-height: 100vh;
  padding: 60rpx 40rpx;
  position: relative;
  overflow: hidden;
}

.login-container::before {
  content: '';
  position: absolute;
  top: -30%;
  left: -20%;
  width: 80%;
  height: 60%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, transparent 70%);
  pointer-events: none;
}

.login-container::after {
  content: '';
  position: absolute;
  bottom: -20%;
  right: -30%;
  width: 70%;
  height: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  pointer-events: none;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
  padding-top: 60rpx;
  position: relative;
  z-index: 1;
}

.logo {
  width: 180rpx;
  height: 180rpx;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.3) 0%, rgba(255, 255, 255, 0.15) 100%);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto 48rpx;
  backdrop-filter: blur(16rpx);
  border: 4rpx solid rgba(255, 255, 255, 0.25);
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
}

.title {
  font-size: 52rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 20rpx;
  text-shadow: none;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  font-weight: 500;
}

.login-content {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 64rpx 48rpx;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.12);
  position: relative;
  z-index: 1;
}

.mode-switch {
  display: flex;
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 48rpx;
}

.mode-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  font-weight: 600;
}

.mode-item.active {
  background: linear-gradient(135deg, #222222 0%, #222222 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.35);
}

.form-section {
  padding: 20rpx 0;
}

.api-tip-card {
  margin-bottom: 36rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #fff7ed;
  border: 2rpx solid #fdba74;
}

.api-tip-title {
  font-size: 28rpx;
  line-height: 1.5;
  color: #9a3412;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.api-tip-text {
  font-size: 24rpx;
  line-height: 1.7;
  color: #9a3412;
  margin-bottom: 12rpx;
}

.api-tip-text:last-of-type {
  margin-bottom: 20rpx;
}

.api-config-input {
  margin-bottom: 20rpx;
}

.api-action-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.api-action-button {
  flex: 1;
}

.form-item {
  margin-bottom: 44rpx;
}

.input {
  width: 100%;
}

.login-btn {
  width: 100%;
  margin-top: 48rpx;
  margin-bottom: 32rpx;
  height: 100rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.tips {
  text-align: left;
  padding: 32rpx;
  background: #f0f4ff;
  border-radius: 16rpx;
  border-left: 6rpx solid #222222;
}

.tip-item {
  font-size: 24rpx;
  color: #4a5568;
  font-weight: 500;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.tip-item:last-child {
  margin-bottom: 0;
}

.code-input-wrapper {
  display: flex;
  gap: 20rpx;
}

.code-input {
  flex: 1;
}

.code-tip {
  margin-top: 16rpx;
}

.code-tip .tip-text {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

.captcha-row {
  display: flex;
  align-items: stretch;
  gap: 20rpx;
}

.captcha-input {
  flex: 1;
}

.captcha-image-box {
  width: 220rpx;
  height: 88rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid #e5e7eb;
  background: #f8fafc;
  display: flex;
  align-items: center;
  justify-content: center;
}

.captcha-image {
  width: 100%;
  height: 100%;
}

.captcha-placeholder {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
}

.captcha-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
}

.lock-tip {
  margin-top: 8rpx;
  margin-bottom: 8rpx;
  padding: 16rpx 20rpx;
  border-radius: 14rpx;
  background: #fff7ed;
  color: #9a3412;
  font-size: 24rpx;
  line-height: 1.5;
}

@media (min-width: 750rpx) {
  .login-container {
    padding: 100rpx 80rpx;
  }

  .header {
    margin-bottom: 120rpx;
  }

  .login-content {
    padding: 80rpx 72rpx;
  }
}
