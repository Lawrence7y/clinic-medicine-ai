.medical-record-container {
  min-height: 100vh;
  background: #ffffff;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.search-section {
  padding: 24rpx 30rpx;
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stats-section {
  padding: 24rpx 30rpx;
  background: #fff;
  margin-bottom: 24rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stats-card {
  display: flex;
  justify-content: space-around;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  border: 1rpx solid #efefef;
}

.stat-item {
  text-align: center;
  color: #222;
}

.stat-value {
  font-size: 52rpx;
  font-weight: 700;
  display: block;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.stat-label {
  font-size: 26rpx;
  opacity: 1;
  color: #666;
  margin-top: 12rpx;
  font-weight: 500;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 32rpx;
  background: #fff;
  margin-bottom: 24rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s ease;
}

.action-btn:active {
  transform: scale(0.96);
}

.action-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #222222 0%, #222222 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 18rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.12);
}

.action-btn text {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.filter-section {
  display: flex;
  padding: 24rpx 30rpx;
  background: #fff;
  margin-bottom: 24rpx;
  gap: 24rpx;
  flex-wrap: wrap;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.filter-item {
  flex: 1;
  min-width: 220rpx;
}

.picker {
  padding: 18rpx 24rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #f0f2f5 100%);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  transition: all 0.3s ease;
}

.picker:active {
  background: linear-gradient(135deg, #e8ecf0 0%, #e0e4e8 100%);
}

.record-list {
  padding: 0 30rpx;
}

.record-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.record-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.patient-info {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.patient-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.patient-gender,
.patient-age {
  font-size: 26rpx;
  color: #666;
  background: linear-gradient(135deg, #f5f7fa 0%, #f0f2f5 100%);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.record-time {
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
}

.record-body {
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  margin-bottom: 16rpx;
  line-height: 1.7;
}

.info-row .label {
  font-size: 28rpx;
  color: #888;
  width: 130rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.info-row .value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  font-weight: 500;
}

.info-row .diagnosis {
  color: #222222;
  font-weight: 600;
}

.record-footer {
  display: flex;
  gap: 18rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
}
