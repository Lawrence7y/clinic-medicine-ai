.page { min-height: 100vh; background: #f6f7fb; padding: 20rpx; box-sizing: border-box; }
.header { background: #fff; border-radius: 12rpx; padding: 20rpx; margin-bottom: 14rpx; }
.title { display: block; font-size: 30rpx; font-weight: 600; color: #111827; }
.desc { display: block; margin-top: 6rpx; font-size: 22rpx; color: #6b7280; }
.state-actions { display: flex; justify-content: center; align-items: center; margin-top: 12rpx; }
.warn { background: #fff7ed; border: 1rpx solid #fdba74; color: #9a3412; border-radius: 10rpx; padding: 14rpx; margin-bottom: 12rpx; font-size: 24rpx; }
.item-card { background: #fff; border-radius: 12rpx; padding: 18rpx; margin-bottom: 12rpx; }
.row { display: flex; justify-content: space-between; align-items: center; border-bottom: 1rpx solid #f1f5f9; padding: 10rpx 0; gap: 20rpx; }
.row:last-child { border-bottom: none; }
.label { font-size: 24rpx; color: #6b7280; }
.value { font-size: 24rpx; color: #111827; text-align: right; flex: 1; }
.actions { margin-top: 12rpx; display: flex; justify-content: flex-end; }
