<view class="record-detail-container">
  <async-state
    wx:if="{{uiState === 'loading'}}"
    mode="loading"
    title="{{texts.loading}}"
  />

  <async-state
    wx:elif="{{uiState === 'error'}}"
    mode="error"
    title="{{errorText || texts.loadFailed}}"
    buttonText="{{texts.retry}}"
    bind:retry="onRetry"
  />

  <async-state
    wx:elif="{{uiState === 'empty'}}"
    mode="empty"
    title="{{texts.empty}}"
  />

  <block wx:else>
    <view class="header-section">
      <view class="patient-info">
        <text class="patient-name">{{record.patientName || '-'}}</text>
        <text class="patient-basic">{{getGenderText(record.patientGender)}} | {{record.patientAge || '-'}}</text>
      </view>
      <view class="visit-info">
        <text class="visit-time">{{record.visitTime || '-'}}</text>
        <t-tag size="small" theme="primary" variant="light">{{record.department || '门诊'}}</t-tag>
      </view>
    </view>

    <view class="info-section">
      <view class="info-card">
        <view class="card-header">
          <t-icon name="user" size="32rpx" color="#222222" />
          <text class="card-title">患者信息</text>
        </view>
        <view class="info-content">
          <view class="info-row"><text class="label">姓名：</text><text class="value">{{record.patientName || '-'}}</text></view>
          <view class="info-row"><text class="label">性别：</text><text class="value">{{getGenderText(record.patientGender)}}</text></view>
          <view class="info-row"><text class="label">年龄：</text><text class="value">{{record.patientAge || '-'}}</text></view>
          <view class="info-row"><text class="label">手机号：</text><text class="value">{{record.patientPhone || '-'}}</text></view>
        </view>
        <view class="card-actions-inline">
          <t-button size="small" theme="primary" variant="outline" bindtap="goToPatientDetail">查看患者详情</t-button>
        </view>
      </view>

      <view class="info-card">
        <view class="card-header">
          <t-icon name="doctor" size="32rpx" color="#222222" />
          <text class="card-title">就诊信息</text>
        </view>
        <view class="info-content">
          <view class="info-row"><text class="label">就诊时间：</text><text class="value">{{record.visitTime || '-'}}</text></view>
          <view class="info-row"><text class="label">医生：</text><text class="value">{{record.doctorName || '-'}}</text></view>
          <view class="info-row"><text class="label">诊断：</text><text class="value diagnosis">{{record.diagnosis || '-'}}</text></view>
        </view>
      </view>
    </view>

    <view class="detail-section">
      <view class="info-card">
        <view class="card-header">
          <t-icon name="file" size="32rpx" color="#222222" />
          <text class="card-title">病历详情</text>
        </view>
        <view class="info-content">
          <view class="info-row"><text class="label">主诉：</text><text class="value">{{record.chiefComplaint || '-'}}</text></view>
          <view class="info-row"><text class="label">现病史：</text><text class="value">{{record.presentIllness || '-'}}</text></view>
          <view class="info-row"><text class="label">既往史：</text><text class="value">{{record.pastHistory || '-'}}</text></view>
          <view class="info-row"><text class="label">过敏史：</text><text class="value">{{record.allergyHistory || '-'}}</text></view>
          <view class="info-row"><text class="label">体格检查：</text><text class="value">{{record.physicalExam || '-'}}</text></view>
          <view class="info-row"><text class="label">治疗方案：</text><text class="value">{{record.treatment || '-'}}</text></view>
          <view class="info-row"><text class="label">复诊建议：</text><text class="value">{{record.followUp || '-'}}</text></view>
        </view>
      </view>
    </view>

    <view class="prescription-section" wx:if="{{record.prescription && record.prescription.length > 0}}">
      <view class="info-card">
        <view class="card-header">
          <t-icon name="medicine-box" size="32rpx" color="#222222" />
          <text class="card-title">处方信息</text>
        </view>
        <view class="card-actions-inline">
          <t-button size="small" theme="primary" bindtap="goToPrescriptionPage">打开处方详情</t-button>
        </view>
        <view class="prescription-list">
          <view class="prescription-item" wx:for="{{record.prescription}}" wx:key="index">
            <view class="medicine-info">
              <text class="medicine-name">{{item.name || '-'}}</text>
              <text class="medicine-dosage">{{item.dosage || '-'}} x {{item.days || '-'}}天</text>
            </view>
            <view class="medicine-side">
              <text class="medicine-frequency">{{item.frequency || '-'}}</text>
              <text
                class="medicine-link"
                wx:if="{{item.medicineId}}"
                bindtap="goToMedicineDetail"
                data-medicine-id="{{item.medicineId}}"
              >
                查看药品
              </text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="prescription-section" wx:if="{{canUseAiAssistant}}">
      <view class="info-card">
        <view class="card-header">
          <t-icon name="chat" size="32rpx" color="#0f766e" />
          <text class="card-title">AI 病历助手</text>
        </view>
        <view class="card-actions-inline">
          <t-button size="small" theme="primary" bindtap="goToAiMedicalAssistant">生成病历建议</t-button>
        </view>
      </view>
    </view>

    <view class="action-section" wx:if="{{canEdit}}">
      <ui-button theme="primary" size="large" bind:tap="editRecord">编辑病历</ui-button>
      <ui-button theme="danger" size="large" variant="outline" bind:tap="deleteRecord">删除病历</ui-button>
    </view>
  </block>

  <t-toast id="t-toast" />
</view>
