.record-detail-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 头部信息 */
.header-section {
  background: #222222;
  padding: 40rpx 30rpx;
  color: #fff;
}

.patient-info {
  margin-bottom: 20rpx;
}

.patient-name {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.patient-basic {
  font-size: 28rpx;
  opacity: 0.9;
}

.visit-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.visit-time {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 信息区域 */
.info-section {
  padding: 30rpx;
}

.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-left: 12rpx;
}

.info-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-row {
  display: flex;
  align-items: flex-start;
  font-size: 28rpx;
}

.info-row .label {
  color: #999;
  width: 140rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
}

.info-row .value {
  color: #333;
  flex: 1;
  line-height: 1.5;
}

.info-row .diagnosis {
  color: #222222;
  font-weight: 500;
}

/* 处方信息 */
.prescription-section {
  padding: 0 30rpx 30rpx;
}

.prescription-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.prescription-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
}

.medicine-info {
  flex: 1;
}

.medicine-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 4rpx;
}

.medicine-dosage {
  font-size: 24rpx;
  color: #666;
}

.medicine-frequency {
  font-size: 26rpx;
  color: #222222;
  font-weight: 500;
}

.medicine-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.medicine-link {
  font-size: 22rpx;
  color: #2563eb;
}

.card-actions-inline {
  margin-top: 14rpx;
  display: flex;
  justify-content: flex-end;
}

/* 操作按钮 */
.action-section {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-section t-button {
  width: 100%;
}
