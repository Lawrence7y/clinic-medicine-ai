.medicine-container {
  min-height: 100vh;
  background: #f7faf9;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.search-section {
  padding: 24rpx 30rpx;
  background: #fff;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stats-section {
  padding: 24rpx 30rpx;
  margin-top: 20rpx;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.stat-card {
  background: #fff;
  border-radius: 22rpx;
  padding: 28rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(15, 23, 42, 0.06);
  border: 1rpx solid #edf2f7;
}

.stat-card.warning {
  background: linear-gradient(135deg, #fff5f5 0%, #fffafa 100%);
  border-color: #fed7d7;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #111827;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 10rpx;
  font-weight: 500;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 24rpx;
  background: #fff;
  margin: 24rpx 30rpx 0;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(15, 23, 42, 0.06);
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: transform 0.2s ease;
}

.action-btn:active {
  transform: scale(0.96);
}

.action-icon {
  width: 112rpx;
  height: 112rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #111827 0%, #0f766e 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 18rpx;
  box-shadow: 0 8rpx 20rpx rgba(15, 23, 42, 0.12);
}

.action-icon--green {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.action-icon--orange {
  background: linear-gradient(135deg, #fc4a1a 0%, #f7b733 100%);
}

.action-icon--blue {
  background: linear-gradient(135deg, #00b4db 0%, #0083b0 100%);
}

.action-icon--teal {
  background: linear-gradient(135deg, #0f766e 0%, #14b8a6 100%);
}

.action-btn text {
  font-size: 26rpx;
  color: #334155;
  font-weight: 500;
}

.warning-banner {
  padding: 0 30rpx;
  margin-top: 24rpx;
}

.filter-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 30rpx;
  margin: 24rpx 30rpx 0;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.filter-item {
  display: flex;
  align-items: center;
}

.picker {
  padding: 18rpx 28rpx;
  background: linear-gradient(135deg, #f8fafc 0%, #eef2f7 100%);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
  transition: all 0.2s ease;
}

.picker--active {
  background: linear-gradient(135deg, #e0f2fe 0%, #cffafe 100%);
  color: #0f766e;
}

.content-section {
  padding-top: 24rpx;
}

.medicine-list {
  padding: 0 30rpx;
}

.medicine-card,
.prescription-medicine-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 6rpx 24rpx rgba(15, 23, 42, 0.06);
  border-left: 8rpx solid transparent;
}

.medicine-card:active,
.prescription-medicine-card:active {
  transform: scale(0.99);
}

.medicine-card.warning {
  border-left-color: #ef4444;
  background: linear-gradient(135deg, #fff5f5 0%, #fffdfd 100%);
}

.medicine-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.medicine-info {
  flex: 1;
}

.medicine-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #0f172a;
  display: block;
  margin-bottom: 10rpx;
}

.medicine-spec {
  font-size: 26rpx;
  color: #64748b;
  font-weight: 500;
}

.medicine-body {
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  margin-bottom: 12rpx;
}

.info-row .label {
  font-size: 26rpx;
  color: #94a3b8;
  width: 140rpx;
  font-weight: 500;
}

.info-row .value {
  font-size: 26rpx;
  color: #334155;
  flex: 1;
  font-weight: 500;
}

.medicine-footer {
  display: flex;
  justify-content: space-between;
  padding-top: 24rpx;
  border-top: 2rpx solid #f1f5f9;
}

.stock-info,
.price-info {
  text-align: center;
}

.stock-label,
.price-label {
  font-size: 24rpx;
  color: #94a3b8;
  display: block;
  margin-bottom: 6rpx;
  font-weight: 500;
}

.stock-value {
  font-size: 38rpx;
  font-weight: 700;
  color: #111827;
}

.stock-value.warning {
  color: #ef4444;
}

.price-value {
  font-size: 38rpx;
  font-weight: 700;
  color: #16a34a;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  padding: 0 0 16rpx;
  margin-bottom: 8rpx;
}
