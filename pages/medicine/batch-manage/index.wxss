.batch-manage-container {
  min-height: 100vh;
  background: #f5f6f8;
  padding: 24rpx;
  box-sizing: border-box;
}

.header-card {
  background: #fff;
  border-radius: 18rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 14rpx rgba(0, 0, 0, 0.05);
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1d2129;
}

.count {
  font-size: 24rpx;
  color: #86909c;
}

.medicine-name {
  margin-top: 10rpx;
  display: block;
  font-size: 26rpx;
  color: #4e5969;
}

.batch-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.batch-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.batch-number-wrap {
  min-width: 0;
  flex: 1;
  margin-right: 12rpx;
}

.batch-number-label {
  font-size: 22rpx;
  color: #86909c;
}

.batch-number {
  margin-top: 4rpx;
  display: block;
  font-size: 28rpx;
  color: #1d2129;
  font-weight: 600;
}

.card-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}

.label {
  color: #86909c;
  font-size: 24rpx;
}

.value {
  color: #1d2129;
  font-size: 24rpx;
}

.value.strong {
  color: #2f9f3d;
  font-weight: 700;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}
