.medicine-detail-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

.info-section {
  background: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.section-title text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-left: 12rpx;
  flex: 1;
}

.info-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  min-width: 200rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  word-break: break-word;
}

.info-value.price {
  color: #ff4d4f;
  font-weight: bold;
}

.info-value.stock {
  color: #52c41a;
  font-weight: bold;
  font-size: 32rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-card {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-date {
  font-size: 24rpx;
  color: #999;
}

.record-body {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.record-amount {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.record-doctor {
  font-size: 24rpx;
  color: #666;
}

.empty-record {
  padding: 60rpx 0;
  text-align: center;
}

.action-section {
  padding: 30rpx;
}

.action-section t-button {
  width: 100%;
}
