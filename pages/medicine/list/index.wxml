<view class="medicine-list-container">
  <view class="search-section">
    <t-search value="{{searchKeyword}}" placeholder="搜索药品名称" bind:change="onSearchChange" bind:submit="onSearch" bind:search="onSearch" />
    <picker mode="selector" range="{{dosageForms}}" bindchange="onFormChange">
      <view class="filter-btn">
        <t-icon name="filter" size="32rpx" color="#222222" />
        <text>{{selectedForm || '全部剂型'}}</text>
      </view>
    </picker>
  </view>

  <view class="quick-actions" wx:if="{{isAdmin}}">
    <view class="quick-action-card primary" bindtap="goToAdd">
      <view class="quick-action-icon">
        <t-icon name="add" size="40rpx" color="#ffffff" />
      </view>
      <text class="quick-action-label">新建药品</text>
    </view>
    <view class="quick-action-card success" bindtap="goToStockIn">
      <view class="quick-action-icon">
        <t-icon name="download" size="40rpx" color="#ffffff" />
      </view>
      <text class="quick-action-label">入库</text>
    </view>
    <view class="quick-action-card warning" bindtap="goToStockOut">
      <view class="quick-action-icon">
        <t-icon name="upload" size="40rpx" color="#ffffff" />
      </view>
      <text class="quick-action-label">出库</text>
    </view>
  </view>

  <view class="medicine-list">
    <async-state
      wx:if="{{uiState === 'loading'}}"
      mode="loading"
      title="加载中..."
    />

    <async-state
      wx:elif="{{uiState === 'error'}}"
      mode="error"
      title="{{errorMessage || '加载药品列表失败'}}"
      buttonText="重试"
      bind:retry="onRetry"
    />

    <async-state
      wx:elif="{{medicineList.length === 0}}"
      mode="empty"
      title="暂无药品信息"
    />

    <view wx:else class="medicine-cards">
      <view wx:for="{{medicineList}}" wx:key="id" class="medicine-card" bindtap="goToDetail" data-medicine="{{item}}">
        <view class="medicine-header">
          <view class="medicine-info">
            <view class="medicine-name-row">
              <text class="medicine-name">{{item.name}}</text>
              <view wx:if="{{item.isPrescription}}" class="prescription-tag">处方药</view>
              <view wx:else class="otc-tag">非处方药</view>
            </view>
            <text class="medicine-spec">{{item.specification || '-'}}</text>
          </view>
          <view class="medicine-form">{{item.dosageForm || '-'}}</view>
        </view>

        <view class="medicine-body">
          <view class="info-row">
            <text class="label">库存:</text>
            <text class="value {{item.stock <= (item.warningStock || item.minStock || 10) ? 'warning' : ''}}">{{item.stock}}</text>
          </view>
          <view class="info-row">
            <text class="label">价格:</text>
            <text class="value price">￥{{item.price}}</text>
          </view>
        </view>

        <view class="medicine-actions" wx:if="{{isAdmin}}" catchtap="stopPropagation">
          <t-button theme="light" size="small" bindtap="goToEdit" data-medicine="{{item}}">编辑</t-button>
          <t-button theme="danger" size="small" bindtap="handleDelete" data-medicine="{{item}}">删除</t-button>
        </view>
      </view>
    </view>
  </view>

  <t-toast id="t-toast" />
</view>
