.medicine-list-container {
  min-height: 100vh;
  background: #ffffff;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

/* 搜索栏 */
.search-section {
  background: #fff;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.search-section t-search {
  flex: 1;
}

.filter-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 18rpx 24rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #f0f2f5 100%);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  transition: all 0.3s ease;
}

.filter-btn:active {
  background: linear-gradient(135deg, #e8ecf0 0%, #e0e4e8 100%);
}

/* 快捷操作 */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  padding: 24rpx 30rpx 0;
}

.quick-action-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.05);
}

.quick-action-card:active {
  transform: scale(0.98);
}

.quick-action-card.primary {
  background: linear-gradient(135deg, #222222 0%, #3b3b3b 100%);
}

.quick-action-card.success {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.quick-action-card.warning {
  background: linear-gradient(135deg, #fc4a1a 0%, #f7b733 100%);
}

.quick-action-icon {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.18);
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-action-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #ffffff;
}

.medicine-list {
  padding: 24rpx 30rpx;
}

.medicine-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.medicine-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.medicine-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.medicine-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.medicine-info {
  flex: 1;
}

.medicine-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.medicine-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.prescription-tag {
  font-size: 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #ff4d4f 0%, #ff7875 100%);
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.otc-tag {
  font-size: 20rpx;
  color: #52c41a;
  background: linear-gradient(135deg, #f6ffed 0%, #f0f9ff 100%);
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 600;
  border: 1rpx solid #52c41a;
}

.medicine-spec {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.medicine-form {
  font-size: 22rpx;
  color: #fff;
  background: linear-gradient(135deg, #222222 0%, #222222 100%);
  padding: 8rpx 18rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.medicine-body {
  margin-bottom: 24rpx;
}

.info-row {
  display: flex;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-row .label {
  color: #888;
  min-width: 100rpx;
  font-weight: 500;
}

.info-row .value {
  color: #333;
  flex: 1;
  font-weight: 500;
}

.info-row .value.warning {
  color: #ff4d4f;
  font-weight: 600;
}

.info-row .value.price {
  color: #ff6b6b;
  font-weight: 700;
}

.medicine-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
}
