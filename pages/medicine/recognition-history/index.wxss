.history-page {
  min-height: 100vh;
  padding: 24rpx;
  background: #f6f8fb;
  box-sizing: border-box;
}

.state-block {
  padding: 48rpx 24rpx;
  text-align: center;
  color: #64748b;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.history-card {
  padding: 24rpx;
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.08);
}

.history-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.history-time {
  font-weight: 600;
  color: #111827;
}

.history-scene {
  color: #0f766e;
}

.history-row {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.history-row .label {
  min-width: 120rpx;
  color: #64748b;
}

.history-row .value {
  flex: 1;
  color: #111827;
  word-break: break-all;
}

.value-action {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.action-link {
  color: #0f766e;
  font-size: 24rpx;
}

.value-block {
  display: block;
}

.value-sub {
  display: block;
  color: #64748b;
  margin-top: 4rpx;
  font-size: 24rpx;
}

.candidate-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.candidate-item {
  padding: 10rpx 12rpx;
  border-radius: 10rpx;
  background: #f8fafc;
}

.evidence-list {
  margin-top: 6rpx;
}

.diff-row {
  margin-top: 8rpx;
  padding: 8rpx 12rpx;
  border-radius: 10rpx;
  background: #f8fafc;
}

.diff-field {
  display: block;
  color: #334155;
  font-size: 24rpx;
  font-weight: 500;
}

.diff-value {
  display: block;
  color: #64748b;
  font-size: 22rpx;
  margin-top: 2rpx;
}
