<view class="stock-in-container">
  <view class="stats-section">
    <view class="stats-card">
      <view class="stat-item">
        <text class="stat-value">{{stockInHistory.length}}</text>
        <text class="stat-label">入库记录</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{todayCount}}</text>
        <text class="stat-label">今日入库</text>
      </view>
    </view>
  </view>

  <view class="action-section">
    <t-button theme="primary" size="large" block bindtap="openAddModal">新建入库</t-button>
  </view>

  <view class="record-list">
    <async-state
      wx:if="{{uiState === 'loading'}}"
      mode="loading"
      title="加载中..."
    />

    <async-state
      wx:elif="{{uiState === 'error'}}"
      mode="error"
      title="{{errorText || '加载入库记录失败'}}"
      buttonText="重试"
      bind:retry="onRetry"
    />

    <async-state
      wx:elif="{{uiState === 'empty'}}"
      mode="empty"
      title="暂无入库记录"
      description="点击上方按钮开始新建入库"
    />

    <view wx:else class="record-cards">
      <view wx:for="{{stockInHistory}}" wx:key="id" class="record-card">
        <view class="card-top">
          <view class="medicine-info">
            <view class="medicine-icon">
              <t-icon name="gift" size="40rpx" color="#52c41a" />
            </view>
            <view class="medicine-detail">
              <text class="medicine-name">{{item.medicineName}}</text>
              <text class="medicine-batch">入库日期：{{item.stockInDate}} | 有效期：{{item.expiryDate}}</text>
            </view>
          </view>
          <t-tag theme="success" size="small" variant="light">入库成功</t-tag>
        </view>

        <view class="card-middle">
          <view class="info-grid">
            <view class="info-item">
              <text class="info-label">入库数量</text>
              <text class="info-value quantity">{{item.quantity}}</text>
            </view>
            <view class="info-item">
              <text class="info-label">操作人</text>
              <text class="info-value">{{item.operator}}</text>
            </view>
            <view class="info-item">
              <text class="info-label">入库时间</text>
              <text class="info-value time">{{item.createTime}}</text>
            </view>
          </view>
        </view>

        <view class="card-bottom" wx:if="{{item.remark}}">
          <t-icon name="info-circle" size="28rpx" color="#999" />
          <text class="remark-text">{{item.remark}}</text>
        </view>
      </view>
    </view>
  </view>

  <t-popup visible="{{showAddModal}}" placement="bottom" bind:close="closeAddModal">
    <view class="modal-content">
      <view class="modal-header">
        <view class="modal-title">
          <t-icon name="add-circle" size="40rpx" color="#222222" />
          <text>药品入库</text>
        </view>
        <t-icon name="close" size="40rpx" bindtap="closeAddModal" />
      </view>

      <scroll-view class="modal-body" scroll-y>
        <view class="form-section-wrapper">
          <view class="section-divider">
            <view class="divider-line"></view>
            <view class="divider-title">
              <t-icon name="medicine-box" size="28rpx" color="#222222" />
              <text>选择药品</text>
            </view>
            <view class="divider-line"></view>
          </view>

          <view class="form-section">
            <view class="medicine-action-row">
              <view class="medicine-search-wrapper flex-1">
                <t-input value="{{medicineSearchKeyword}}" bind:change="onMedicineSearch" placeholder="请输入药品名称、厂家或条码" clearable prefixIcon="search" />
                <view wx:if="{{showMedicineDropdown}}" class="medicine-dropdown">
                  <view wx:for="{{filteredMedicineList}}" wx:key="id" class="medicine-dropdown-item" bindtap="onMedicineSelect" data-id="{{item.id}}">
                    <view class="dropdown-medicine-info">
                      <text class="dropdown-medicine-name">{{item.displayName || item.name}}</text>
                      <text class="dropdown-medicine-spec">{{item.specification}}</text>
                    </view>
                    <view class="dropdown-medicine-meta">
                      <text class="dropdown-medicine-stock">库存：{{item.stock}}</text>
                    </view>
                  </view>
                </view>
              </view>
              <t-button theme="primary" variant="outline" size="small" loading="{{scanLoading}}" bindtap="handleScanSelectMedicine">扫码选药</t-button>
            </view>

            <view wx:if="{{formData.medicineId}}" class="selected-medicine">
              <t-icon name="check-circle" size="32rpx" color="#52c41a" />
              <view class="selected-content">
                <text class="selected-text">{{selectedMedicineDisplayName || formData.medicineName}}</text>
                <text class="selected-extra" wx:if="{{selectedMedicineExtra}}">{{selectedMedicineExtra}}</text>
              </view>
            </view>
          </view>
        </view>

        <view class="form-section-wrapper">
          <view class="section-divider">
            <view class="divider-line"></view>
            <view class="divider-title">
              <t-icon name="edit" size="28rpx" color="#222222" />
              <text>入库信息</text>
            </view>
            <view class="divider-line"></view>
          </view>

          <view class="form-section">
            <view class="form-item">
              <view class="form-label"><text>入库数量 <text class="required">*</text></text></view>
              <t-input type="number" value="{{formData.quantity}}" bind:change="onFormFieldChange" data-field="quantity" placeholder="请输入入库数量" />
            </view>

            <view class="form-item">
              <view class="form-label"><text>批次号 <text class="required">*</text></text></view>
              <t-input value="{{formData.batchNumber}}" bind:change="onFormFieldChange" data-field="batchNumber" placeholder="请输入批次号" />
            </view>

            <view class="form-row">
              <view class="form-item flex-1">
                <view class="form-label"><text>入库日期</text></view>
                <view class="picker-input">{{formData.stockInDate}}</view>
              </view>
              <view class="form-item flex-1">
                <view class="form-label"><text>有效期 <text class="required">*</text></text></view>
                <picker mode="date" value="{{formData.expiryDate}}" bindchange="onExpiryDateChange">
                  <view class="picker-input">{{formData.expiryDate || '请选择有效期'}}</view>
                </picker>
              </view>
            </view>

            <view class="form-item">
              <view class="form-label"><text>备注</text></view>
              <t-textarea value="{{formData.remark}}" bind:change="onFormFieldChange" data-field="remark" placeholder="请输入备注信息（选填）" autosize="{{true}}" maxlength="200" />
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="modal-footer">
        <t-button variant="outline" size="large" block bindtap="closeAddModal">取消</t-button>
        <t-button theme="primary" size="large" block bindtap="handleSubmit" loading="{{loading}}">确认入库</t-button>
      </view>
    </view>
  </t-popup>

  <t-toast id="t-toast" />
</view>
