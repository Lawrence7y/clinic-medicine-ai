<view class="stock-out-container">
  <view class="stats-section">
    <view class="stats-card">
      <view class="stat-item">
        <text class="stat-value">{{stockOutHistory.length}}</text>
        <text class="stat-label">出库记录</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{todayCount}}</text>
        <text class="stat-label">今日出库</text>
      </view>
    </view>
  </view>

  <view class="action-section">
    <t-button theme="primary" size="large" block bindtap="openAddModal">新建出库</t-button>
  </view>

  <view class="record-list">
    <async-state
      wx:if="{{uiState === 'loading'}}"
      mode="loading"
      title="加载中..."
    />

    <async-state
      wx:elif="{{uiState === 'error'}}"
      mode="error"
      title="{{errorText || '加载出库记录失败'}}"
      buttonText="重试"
      bind:retry="onRetry"
    />

    <async-state
      wx:elif="{{uiState === 'empty'}}"
      mode="empty"
      title="暂无出库记录"
      description="点击上方按钮开始新建出库"
    />

    <view wx:else class="record-cards">
      <view wx:for="{{stockOutHistory}}" wx:key="id" class="record-card">
        <view class="card-top">
          <view class="medicine-info">
            <view class="medicine-icon">
              <t-icon name="cart" size="40rpx" color="#ff4d4f" />
            </view>
            <view class="medicine-detail">
              <text class="medicine-name">{{item.medicineName}}</text>
              <text class="medicine-patient">{{item.patientName}}</text>
            </view>
          </view>
          <t-tag theme="warning" size="small" variant="light">出库成功</t-tag>
        </view>

        <view class="card-middle">
          <view class="info-grid">
            <view class="info-item">
              <text class="info-label">出库数量</text>
              <text class="info-value quantity">{{item.quantity}}</text>
            </view>
            <view class="info-item">
              <text class="info-label">患者</text>
              <text class="info-value">{{item.patientName || '-'}}</text>
            </view>
            <view class="info-item">
              <text class="info-label">医生</text>
              <text class="info-value">{{item.doctorName || '-'}}</text>
            </view>
            <view class="info-item">
              <text class="info-label">操作人</text>
              <text class="info-value">{{item.operator}}</text>
            </view>
            <view class="info-item full-width">
              <text class="info-label">出库时间</text>
              <text class="info-value time">{{item.createTime}}</text>
            </view>
          </view>
        </view>

        <view class="card-bottom" wx:if="{{item.remark}}">
          <t-icon name="info-circle" size="28rpx" color="#999" />
          <text class="remark-text">{{item.remark}}</text>
        </view>
      </view>
    </view>
  </view>

  <t-popup visible="{{showAddModal}}" placement="bottom" bind:close="closeAddModal">
    <view class="modal-content">
      <view class="modal-header">
        <view class="modal-title">药品出库</view>
        <t-icon name="close" size="40rpx" bindtap="closeAddModal" />
      </view>

      <scroll-view class="modal-body" scroll-y>
        <view class="form-section-wrapper">
          <view class="section-divider">
            <view class="divider-line"></view>
            <view class="divider-title">
              <t-icon name="medicine-box" size="32rpx" />
              <text>选择药品</text>
            </view>
            <view class="divider-line"></view>
          </view>

          <view class="form-section">
            <view class="medicine-action-row">
              <view class="medicine-search-wrapper flex-1">
                <t-input value="{{medicineSearchKeyword}}" bind:change="onMedicineSearch" placeholder="请输入药品名称、厂家或条码" clearable prefixIcon="search" />
                <view wx:if="{{showMedicineDropdown}}" class="medicine-dropdown">
                  <view wx:for="{{filteredMedicineList}}" wx:key="id" class="medicine-dropdown-item" bindtap="onMedicineSelect" data-id="{{item.id}}">
                    <view class="dropdown-medicine-info">
                      <text class="dropdown-medicine-name">{{item.displayName || item.name}}</text>
                      <text class="dropdown-medicine-spec">{{item.specification}}</text>
                    </view>
                    <view class="dropdown-medicine-meta">
                      <t-tag wx:if="{{item.isPrescription}}" size="small" theme="danger" variant="light">处方药</t-tag>
                      <text class="dropdown-medicine-stock">库存：{{item.stock}}</text>
                    </view>
                  </view>
                </view>
              </view>
              <t-button theme="primary" variant="outline" size="small" loading="{{scanLoading}}" bindtap="handleScanSelectMedicine">扫码选药</t-button>
            </view>

            <view wx:if="{{formData.medicineId}}" class="selected-medicine">
              <t-icon name="check-circle" size="32rpx" color="#ff4d4f" />
              <view class="selected-content">
                <text class="selected-text">{{selectedMedicineDisplayName || formData.medicineName}}</text>
                <text class="selected-extra" wx:if="{{selectedMedicineExtra}}">{{selectedMedicineExtra}}</text>
              </view>
            </view>

            <view wx:if="{{formData.medicineId}}" class="form-item batch-picker-item">
              <view class="form-label">选择批次 <text class="required">*</text></view>
              <picker mode="selector" range="{{batchOptionList}}" bindchange="onBatchChange">
                <view class="picker-input">{{formData.batchId ? formData.batchNumber : '请选择出库批次'}}</view>
              </picker>
              <view wx:if="{{formData.batchExpiryDate}}" class="batch-picker-tip">有效期：{{formData.batchExpiryDate}}</view>
              <view wx:if="{{medicineBatchList.length > 0}}" class="batch-picker-tip">共 {{medicineBatchList.length}} 个可出库批次</view>
              <view wx:elif="{{formData.medicineId}}" class="batch-picker-tip batch-picker-empty">当前药品暂无可出库批次</view>
            </view>

            <view wx:if="{{selectedMedicineIsPrescription}}" class="prescription-warning">
              <t-icon name="info-circle" size="32rpx" color="#ff4d4f" />
              <text class="warning-text">该药品为处方药，必须关联病历后才能出库。</text>
            </view>
          </view>
        </view>

        <view class="form-section-wrapper">
          <view class="section-divider">
            <view class="divider-line"></view>
            <view class="divider-title">
              <t-icon name="edit" size="32rpx" />
              <text>出库信息</text>
            </view>
            <view class="divider-line"></view>
          </view>

          <view class="form-section">
            <view class="form-item">
              <view class="form-label">出库数量 <text class="required">*</text></view>
              <t-input type="number" value="{{formData.quantity}}" bind:change="onFormFieldChange" data-field="quantity" placeholder="请输入出库数量" />
            </view>

            <view class="form-item">
              <view class="form-label">选择病历</view>
              <picker mode="selector" range="{{medicalRecordList}}" range-key="displayText" bindchange="onMedicalRecordSelect">
                <view class="picker-input">{{formData.medicalRecordInfo || '请选择病历（处方药必填）'}}</view>
              </picker>
            </view>

            <view class="form-item" wx:if="{{prescriptionMedicineList.length > 0}}">
              <view class="form-label">处方药品</view>
              <picker mode="selector" range="{{prescriptionMedicineList}}" range-key="displayText" bindchange="onPrescriptionMedicineSelect">
                <view class="picker-input">{{formData.prescriptionMedicineInfo || '请选择病历中的药品'}}</view>
              </picker>
            </view>

            <view class="form-row">
              <view class="form-item flex-1">
                <view class="form-label">患者姓名</view>
                <t-input value="{{formData.patientName}}" bind:change="onFormFieldChange" data-field="patientName" placeholder="请输入患者姓名" />
              </view>
              <view class="form-item flex-1">
                <view class="form-label">开方医生</view>
                <t-input value="{{formData.doctorName}}" bind:change="onFormFieldChange" data-field="doctorName" placeholder="请输入医生姓名" />
              </view>
            </view>

            <view class="form-item">
              <view class="form-label">用法用量</view>
              <t-textarea value="{{formData.usage}}" bind:change="onFormFieldChange" data-field="usage" placeholder="请输入药品用法用量" autosize="{{true}}" maxlength="200" />
            </view>

            <view class="form-item">
              <view class="form-label">备注</view>
              <t-textarea value="{{formData.remark}}" bind:change="onFormFieldChange" data-field="remark" placeholder="请输入备注信息（选填）" autosize="{{true}}" maxlength="200" />
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="modal-footer">
        <t-button variant="outline" size="large" block bindtap="closeAddModal">取消</t-button>
        <t-button theme="danger" size="large" block bindtap="handleSubmit" loading="{{loading}}">确认出库</t-button>
      </view>
    </view>
  </t-popup>

  <t-toast id="t-toast" />
</view>
