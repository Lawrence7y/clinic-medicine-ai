.stock-out-container {
  min-height: 100vh;
  background: #ffffff;
}

.stats-section {
  padding: 24rpx 30rpx;
  background: #fff;
  margin-bottom: 24rpx;
  margin-top: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stats-card {
  display: flex;
  justify-content: space-around;
  background: linear-gradient(135deg, #222222 0%, #222222 100%);
  border-radius: 24rpx;
  padding: 48rpx 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(34, 34, 34, 0.18);
}

.stat-item {
  text-align: center;
  color: #fff;
}

.stat-value {
  font-size: 52rpx;
  font-weight: 700;
  display: block;
}

.stat-label {
  font-size: 26rpx;
  opacity: 0.95;
  margin-top: 12rpx;
  font-weight: 500;
}

.stat-divider {
  width: 2rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.2);
}

.action-section {
  padding: 0 24rpx 24rpx;
}

.record-list {
  padding: 0 24rpx 24rpx;
}

.record-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.medicine-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.medicine-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  background: linear-gradient(135deg, #fff1f0 0%, #ffe0e0 100%);
}

.medicine-detail {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.medicine-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
}

.medicine-patient {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.card-middle {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
}

.info-item.full-width {
  grid-column: 1 / -1;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.info-value.quantity {
  color: #ff4d4f;
  font-size: 32rpx;
  font-weight: 700;
}

.info-value.time {
  font-size: 24rpx;
  color: #666;
}

.card-bottom {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.remark-text {
  flex: 1;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.modal-content {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.modal-body {
  flex: 1;
  padding: 32rpx;
  overflow-y: auto;
}

.form-section-wrapper {
  margin-bottom: 40rpx;
}

.form-section-wrapper:last-child {
  margin-bottom: 0;
}

.section-divider {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  gap: 16rpx;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, #e0e0e0 50%, transparent 100%);
}

.divider-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #222222;
  white-space: nowrap;
}

.form-section {
  background: linear-gradient(135deg, #fafbff 0%, #f8f9ff 100%);
  border-radius: 16rpx;
  padding: 28rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  display: flex;
  align-items: center;
}

.required {
  color: #ff4d4f;
  margin-left: 4rpx;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.flex-1 {
  flex: 1;
}

.picker-input {
  padding: 20rpx 16rpx;
  background: #fafafa;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  min-height: 48rpx;
  display: flex;
  align-items: center;
}

.medicine-search-wrapper {
  position: relative;
}

.medicine-action-row {
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.medicine-dropdown {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background: #fff;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  max-height: 480rpx;
  overflow-y: auto;
  z-index: 1000;
  margin-top: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.medicine-dropdown-item {
  display: flex;
  flex-direction: column;
  padding: 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  gap: 8rpx;
}

.medicine-dropdown-item:last-child {
  border-bottom: none;
}

.dropdown-medicine-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.dropdown-medicine-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.dropdown-medicine-spec {
  font-size: 24rpx;
  color: #999;
}

.dropdown-medicine-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.dropdown-medicine-stock {
  font-size: 24rpx;
  color: #999;
  margin-left: auto;
}

.selected-medicine {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #fff1f0 0%, #ffe0e0 100%);
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.selected-content {
  display: flex;
  flex-direction: column;
  margin-left: 12rpx;
}

.selected-text {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: 500;
}

.selected-extra {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
}

.batch-picker-item {
  margin-top: 20rpx;
}

.batch-picker-tip {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #86909c;
}

.batch-picker-empty {
  color: #ff7875;
}

.prescription-warning {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx;
  background-color: #fff1f0;
  border-radius: 8rpx;
  margin-top: 20rpx;
  border: 1rpx solid #ffa39e;
}

.prescription-warning .warning-text {
  font-size: 26rpx;
  color: #ff4d4f;
  flex: 1;
}

.modal-footer {
  padding: 24rpx 32rpx 32rpx;
  display: flex;
  gap: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  background: #fff;
}
