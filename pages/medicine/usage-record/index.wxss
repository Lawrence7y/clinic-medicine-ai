.usage-record-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.search-section {
  background-color: #fff;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.search-section t-search {
  flex: 1;
}

.filter-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 24rpx;
  background-color: #f5f5f5;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
}

.usage-list {
  padding: 20rpx;
}

.usage-cards {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.usage-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.usage-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.medicine-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.usage-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  font-size: 28rpx;
}

.info-row .label {
  color: #666;
  min-width: 140rpx;
}

.info-row .value {
  color: #333;
  flex: 1;
}
