.patient-detail-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 信息区域 */
.info-section {
  background: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
}

.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.section-title text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-left: 12rpx;
  flex: 1;
}

.section-title .link-btn {
  flex: 0;
  margin-left: 0;
  font-size: 24rpx;
  color: #2563eb;
  font-weight: 500;
}

.info-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  min-width: 160rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  word-break: break-word;
}

/* 就诊记录 */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-card {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
  cursor: pointer;
  transition: all 0.3s;
}

.record-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-date {
  font-size: 24rpx;
  color: #999;
}

.record-body {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.record-diagnosis {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.record-doctor {
  font-size: 24rpx;
  color: #666;
}

.empty-record {
  padding: 60rpx 0;
  text-align: center;
}

/* 操作按钮 */
.action-section {
  padding: 30rpx;
}

.action-section t-button {
  width: 100%;
}
