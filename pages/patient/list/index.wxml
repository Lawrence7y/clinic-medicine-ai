<view class="patient-list-container">
  <view class="search-section">
    <t-search
      placeholder="{{texts.searchPlaceholder}}"
      value="{{searchKeyword}}"
      bind:change="onSearchChange"
      bind:submit="onSearch"
    />
  </view>

  <async-state
    wx:if="{{uiState === 'loading'}}"
    mode="loading"
    title="加载中..."
  />

  <async-state
    wx:elif="{{uiState === 'error'}}"
    mode="error"
    title="{{errorMessage || texts.loadFailed}}"
    buttonText="{{texts.retry}}"
    bind:retry="onRetry"
  />

  <view wx:elif="{{patientList.length > 0}}" class="patient-list">
    <view class="patient-card" wx:for="{{patientList}}" wx:key="id" bindtap="goToPatientDetail" data-id="{{item.id}}">
      <view class="patient-header">
        <view class="patient-basic">
          <t-avatar size="medium" text="{{item.name ? item.name[0] : '#'}}"/>
          <view class="patient-info">
            <text class="patient-name">{{item.name || '-'}}</text>
            <view class="patient-tags">
              <text class="tag">{{item.gender === 'male' ? texts.male : texts.female}}</text>
              <text class="tag">{{item.age ? item.age + texts.ageSuffix : '-'}}</text>
            </view>
          </view>
        </view>
        <t-icon name="chevron-right" size="40rpx" color="#ccc"/>
      </view>
      <view class="patient-body">
        <view class="info-item">
          <t-icon name="call" size="28rpx" color="#999"/>
          <text>{{item.phone || '-'}}</text>
        </view>
        <view class="info-item" wx:if="{{item.wechat}}">
          <t-icon name="chat" size="28rpx" color="#07c160"/>
          <text>{{item.wechat}}</text>
        </view>
        <view class="info-item" wx:if="{{item.allergyHistory && item.allergyHistory !== texts.noneAllergy}}">
          <t-icon name="error-circle" size="28rpx" color="#ff4d4f"/>
          <text class="warning-text">{{texts.allergyPrefix}}{{item.allergyHistory}}</text>
        </view>
      </view>
    </view>
  </view>

  <async-state
    wx:else
    mode="empty"
    title="{{texts.empty}}"
  />

  <t-toast id="t-toast"/>
</view>
