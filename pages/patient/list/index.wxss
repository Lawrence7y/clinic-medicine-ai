.patient-list-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

.search-section {
  padding: 20rpx 30rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.patient-list {
  padding: 0 30rpx;
}

.patient-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.patient-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.patient-basic {
  display: flex;
  align-items: center;
}

.patient-info {
  margin-left: 20rpx;
}

.patient-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.patient-tags {
  display: flex;
  gap: 12rpx;
}

.tag {
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.patient-body {
  padding-top: 20rpx;
  border-top: 1rpx solid #eee;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.warning-text {
  color: #ff4d4f;
}
