.medical-history-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}

/* 患者信息 */
.patient-info-section {
  background: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.patient-header {
  display: flex;
  align-items: center;
}

.patient-info {
  margin-left: 24rpx;
  flex: 1;
}

.patient-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.patient-basic {
  font-size: 24rpx;
  color: #666;
}

/* 筛选栏 */
.filter-section {
  background: #fff;
  margin-bottom: 20rpx;
}

.filter-scroll {
  white-space: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.filter-list {
  display: inline-flex;
  padding: 20rpx 30rpx;
  gap: 20rpx;
}

.filter-item {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #666;
  background: #f0f0f0;
  cursor: pointer;
}

.filter-item.active {
  color: #222222;
  background: #e6e8ff;
  font-weight: 500;
}

/* 病历列表 */
.record-list {
  padding: 0 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  cursor: pointer;
  transition: all 0.3s;
}

.record-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.05);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-date {
  font-size: 24rpx;
  color: #999;
}

.record-body {
  margin-bottom: 16rpx;
}

.record-diagnosis {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.record-doctor {
  font-size: 24rpx;
  color: #666;
}

.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.record-chief-complaint {
  font-size: 24rpx;
  color: #999;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 加载更多 */
.load-more {
  margin-top: 40rpx;
  margin-bottom: 20rpx;
}
