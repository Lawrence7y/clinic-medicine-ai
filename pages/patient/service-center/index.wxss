.patient-service-page {
  min-height: 100vh;
  background: #f5f7fb;
  padding: 24rpx;
  box-sizing: border-box;
}

.content {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.panel {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.panel-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 14rpx;
}

.row {
  display: flex;
  font-size: 25rpx;
  margin-bottom: 8rpx;
}

.label {
  width: 120rpx;
  color: #64748b;
  flex-shrink: 0;
}

.value {
  color: #334155;
  flex: 1;
  word-break: break-word;
}

.list-item {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #eef2f7;
}

.list-item:last-child {
  border-bottom: none;
}

.list-main {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.list-name {
  font-size: 27rpx;
  color: #0f172a;
  font-weight: 600;
}

.list-desc {
  font-size: 24rpx;
  color: #475569;
}

.list-time {
  font-size: 23rpx;
  color: #64748b;
}

.empty {
  font-size: 24rpx;
  color: #94a3b8;
}
