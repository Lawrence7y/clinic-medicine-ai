<view class="password-reset-container">
  <view class="form-section">
    <t-input
      wx:if="{{!isAdminReset}}"
      label="旧密码"
      placeholder="请输入当前密码"
      type="password"
      value="{{oldPassword}}"
      bind:change="onOldPasswordChange"
    />
    <t-input
      label="新密码"
      placeholder="请输入新密码（至少 6 位）"
      type="password"
      value="{{newPassword}}"
      bind:change="onPasswordChange"
    />
    <t-input
      label="确认密码"
      placeholder="请再次输入新密码"
      type="password"
      value="{{confirmPassword}}"
      bind:change="onConfirmPasswordChange"
    />
  </view>

  <view class="btn-section">
    <t-button theme="primary" size="large" block bindtap="handleReset" loading="{{loading}}">
      重置密码
    </t-button>
  </view>

  <t-toast id="t-toast"/>
</view>
