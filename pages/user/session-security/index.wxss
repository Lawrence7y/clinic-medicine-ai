.session-security-page {
  min-height: 100vh;
  background: #f6f7fb;
  padding: 24rpx;
}

.header-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1f2937;
}

.header-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.header-actions {
  margin-top: 20rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.session-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.session-card {
  background: #fff;
  border-radius: 18rpx;
  padding: 22rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.session-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.device-text {
  font-size: 28rpx;
  color: #111827;
  font-weight: 500;
}

.session-row {
  display: flex;
  margin-top: 8rpx;
}

.row-label {
  width: 150rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.row-value {
  flex: 1;
  font-size: 24rpx;
  color: #374151;
}

.session-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.current-tip {
  font-size: 24rpx;
  color: #059669;
}
