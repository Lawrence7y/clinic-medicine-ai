.user-list-container {
  min-height: 100vh;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

/* 搜索栏 */
.search-bar {
  background: #fff;
  padding: 24rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 筛选栏 */
.filter-bar {
  background: #fff;
  padding: 0 30rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.status-buttons {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

/* 用户列表 */
.user-list {
  flex: 1;
  padding: 0 30rpx 24rpx;
  overflow-y: auto;
}

.user-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.user-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.user-info t-avatar {
  margin-right: 20rpx;
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.user-role {
  font-size: 24rpx;
  color: #222222;
  background: linear-gradient(135deg, #f0f2ff 0%, #e6e9ff 100%);
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  display: inline-block;
  font-weight: 600;
}

.user-actions {
  display: flex;
  gap: 16rpx;
}

/* 加载更多 */
load-more {
  margin-top: 20rpx;
}

/* 新增按钮 */
.add-button {
  background: #fff;
  padding: 24rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

/* 弹窗内容 */
.modal-content {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  width: 600rpx;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
  margin-bottom: 40rpx;
}

.form-container {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.modal-actions {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
  margin-top: 40rpx;
}

.picker {
  padding: 20rpx 16rpx;
  background: linear-gradient(135deg, #f5f7fa 0%, #f0f2f5 100%);
  border-radius: 16rpx;
  color: #333;
  font-size: 28rpx;
  min-height: 48rpx;
  display: flex;
  align-items: center;
  font-weight: 500;
}

/* 验证码弹窗 */
.code-modal {
  text-align: center;
}

.code-info {
  margin-bottom: 30rpx;
}

.code-user,
.code-phone {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.code-display {
  background: linear-gradient(135deg, #222222 0%, #222222 100%);
  padding: 40rpx;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
}

.code-text {
  font-size: 72rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 10rpx;
}

.code-expire {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.code-expire text {
  color: #ff4d4f;
  font-weight: 600;
}

.code-display-box {
  background: linear-gradient(135deg, #222222 0%, #222222 100%);
  padding: 30rpx;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.code-text-large {
  font-size: 64rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 8rpx;
}

.code-expire-small {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 12rpx;
}
