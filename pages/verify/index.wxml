<view class="verify-container">
  <view class="state-wrapper" wx:if="{{stateMode !== 'success'}}">
    <async-state
      mode="{{stateMode}}"
      title="{{stateTitle}}"
      description="{{stateDescription}}"
      buttonText="{{stateButtonText}}"
      bind:retry="onStateRetry"
    />
  </view>

  <block wx:else>
    <view class="header">
      <view class="logo">
        <t-icon name="clinic" size="120rpx" color="#222222" />
      </view>
      <view class="title">完成注册</view>
      <view class="subtitle">请为当前手机号设置登录密码</view>
    </view>

    <view class="form-section">
      <view class="phone-display">
        <text class="phone-label">手机号：</text>
        <text class="phone-text">{{phone}}</text>
      </view>

      <view class="form-item">
        <text class="label">设置密码</text>
        <t-input
          placeholder="请输入至少 6 位密码"
          value="{{password}}"
          bind:change="onPasswordChange"
          type="password"
          clearable
        />
      </view>

      <view class="form-item">
        <text class="label">确认密码</text>
        <t-input
          placeholder="请再次输入密码"
          value="{{confirmPassword}}"
          bind:change="onConfirmPasswordChange"
          type="password"
          clearable
        />
      </view>

      <t-button
        theme="primary"
        size="large"
        loading="{{loading}}"
        disabled="{{loading}}"
        bind:tap="handleVerify"
        class="submit-btn"
      >
        {{loading ? '提交中...' : '完成注册'}}
      </t-button>
    </view>
  </block>

  <t-toast id="t-toast" />
</view>
