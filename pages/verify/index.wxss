.verify-container {
  min-height: 100vh;
  background: #ffffff;
  padding: 60rpx 40rpx;
}

.state-wrapper {
  padding-top: 120rpx;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
  padding-top: 40rpx;
}

.logo {
  width: 160rpx;
  height: 160rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 0 auto 40rpx;
  backdrop-filter: blur(10px);
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #222222;
  margin-bottom: 16rpx;
  text-shadow: none;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
}

.form-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.phone-display {
  text-align: center;
  padding: 30rpx;
  background-color: #f5f5f5;
  border-radius: 12rpx;
  margin-bottom: 40rpx;
}

.phone-label {
  font-size: 28rpx;
  color: #666;
}

.phone-text {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-left: 10rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-item .label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.submit-btn {
  width: 100%;
  margin-top: 20rpx;
}
